# Local Docker Compose configuration only. Do not use these example values in production.
POSTGRES_DB=internapp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-local-password

# Generate a unique value for every environment. Example: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret

# Optional: required only for AI features.
ANTHROPIC_API_KEY=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
METRICS_TOKEN=
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_AI_MAX=20
TRUST_PROXY_HEADERS=false

# Optional: create the initial administrator on an empty local database.
SEED_ADMIN=0
SEED_ADMIN_PASSWORD=

# Keep empty when using Docker Compose so nginx proxies API requests to the backend container.
# Set an explicit URL, for example https://api.example.com, for a separately hosted frontend.
VITE_API_URL=
VITE_SENTRY_DSN=
VITE_ENVIRONMENT=development
