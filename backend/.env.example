# Backend environment template. Copy to backend/.env only for local non-Docker development.
DATABASE_URL=postgresql://postgres:replace-with-a-local-password@localhost:5433/internapp
SECRET_KEY=replace-with-a-long-random-secret
ANTHROPIC_API_KEY=
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=INFO

# Optional local seed account on an empty database.
SEED_ADMIN=0
SEED_ADMIN_PASSWORD=
