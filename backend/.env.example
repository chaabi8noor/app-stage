# Backend environment template. Copy to backend/.env only for local non-Docker development.
DATABASE_URL=postgresql://postgres:replace-with-a-local-password@localhost:5433/internapp
SECRET_KEY=replace-with-a-long-random-secret
ANTHROPIC_API_KEY=
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
METRICS_TOKEN=
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_AI_MAX=20
# Enable only behind a trusted proxy that overwrites X-Forwarded-For.
TRUST_PROXY_HEADERS=false

# Optional local seed account on an empty database.
SEED_ADMIN=0
SEED_ADMIN_PASSWORD=
